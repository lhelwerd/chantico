{
    "plugins": {
        "commit-analyzer": {
            "name": "default",
            "options": {
                "major_release_rules": ""
            }
        },
        "ci-condition": {
            "name": "github",
            "options": {
                "defaultBranch": "main"
            }
        },
        "provider": {
            "name": "github"
        }
    }
}
